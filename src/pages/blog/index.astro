---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts=(await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
---
<BaseLayout title="全部文章｜Rose Lab" description="浏览 Rose Lab 的幼儿英文、线上外师课、免费资源与家庭陪学文章。">
  <main class="wrap listing-page">
    <header class="page-header"><p class="eyebrow">ROSE LAB JOURNAL</p><h1>全部文章</h1><p>依时间浏览幼儿英文、线上外师课、免费资源与家庭陪学文章。</p></header>
    <div class="article-grid">
      {posts.map(post=>(
        <article class="article-card">
          <a class="article-cover" href={`/blog/${post.slug}/`}><img src={post.data.cover ?? '/sample-cover.png'} alt={post.data.coverAlt ?? post.data.title} /></a>
          <div class="article-card-body"><span class="tag">{post.data.category}</span><h2><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h2><p>{post.data.description}</p><time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time></div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
