---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts=(await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
---
<BaseLayout title="全部文章｜Rose Lab 自學研究所" description="Rose Lab 的幼兒英文、家庭陪學、免費資源與線上外師課文章。">
  <section class="wrap page-header">
    <h1>全部文章</h1>
    <p>依主題整理幼兒英文、家庭陪學、免費資源與線上外師課紀錄。</p>
  </section>
  <section class="wrap block article-stream">
    <div class="simple-post-list">
      {posts.map(post => (
        <article>
          <a href={`/blog/${post.slug}/`}>
            <span class="post-category">{post.data.category}</span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <div class="post-dates"><time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time></div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
