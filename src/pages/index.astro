w---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPosts = posts.filter((post) => post.data.featured);
const roundup = (featuredPosts.length >= 5 ? featuredPosts : posts).slice(0, 5);
const latestPosts = posts;
const popularPosts = [...posts].sort((a, b) => {
  const aRank = a.data.popularRank ?? Number.POSITIVE_INFINITY;
  const bRank = b.data.popularRank ?? Number.POSITIVE_INFINITY;
  if (aRank !== bRank) return aRank - bRank;

  const aScore = a.data.featured ? 1 : 0;
  const bScore = b.data.featured ? 1 : 0;
  if (aScore !== bScore) return bScore - aScore;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const categories = [
  ['幼兒英文', '零基礎、慢熟與第一次接觸英文的真實紀錄。', '/blog?topic=幼兒英文', '#fcecef'],
  ['線上外師課', '試聽、選老師、陪課與孩子沉默時怎麼判斷。', '/blog?topic=線上外師課', '#edf5e9'],
  ['免費資源', 'Starfall、Khan Academy Kids 與家庭實際用法。', '/resources', '#f6f0fb'],
  ['親子共學', '忙碌家庭也能執行的短時間英文安排。', '/blog?topic=親子共學', '#fff3dc'],
];

const serializedLatest = latestPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  date: post.data.pubDate.toLocaleDateString('zh-TW'),
  cover: post.data.cover ?? '/sample-cover.png',
  coverAlt: post.data.coverAlt ?? post.data.title,
  url: `/blog/${post.slug}/`,
}));

const serializedPopular = popularPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  date: post.data.pubDate.toLocaleDateString('zh-TW'),
  cover: post.data.cover ?? '/sample-cover.png',
  coverAlt: post.data.coverAlt ?? post.data.title,
  url: `/blog/${post.slug}/`,
}));
---
<BaseLayout
  title="Rose Lab 自學研究所|孩子英文學習、線上外師課與免費資源"
  description="Rose Lab 由一位無後援雙寶媽建立，分享親子閱讀、幼兒英文、線上外師課、家庭自學與戶外探索的真實經驗，陪台灣家長在有限時間與預算中，找到適合自己家庭的育兒方式。"
>
  <main class="home wrap">

<!--首頁介紹 start-->
<section class="home-intro" aria-labelledby="home-intro-title">
  <p class="eyebrow">
    無後援雙寶媽｜教育圈10年｜家庭育兒實戰
  </p>
  <h1 id="home-intro-title">
    不用把孩子的時間塞滿，<br/>
    陪他們慢慢長出自己的能力
  </h1>
  <p>
    我是沒有後援的雙寶媽，也曾在教育圈工作10年。懷孕後開始全職育兒，
    才發現自己不只喜歡陪伴孩子，也很享受觀察他們怎麼理解世界、發展興趣，慢慢長出自己的樣子。
  </p>
  <p>
    Rose Lab 記錄一個普通家庭真實走過的育兒過程，
    整理我們實際使用過的英文資源、線上外師課、親子閱讀、家庭自學與戶外探索方法。
  </p>
  <p>
    希望幫助同樣時間有限、預算有限，也很重視教育的家長，
    少一點資訊焦慮，更快判斷什麼適合自己的孩子。
  </p>
</section>

<!--首頁介紹 end-->

    <section class="category-grid" aria-label="重要分類">
      {categories.map(([title, desc, url, color]) => (
        <a class="category-card" href={url} style={`--card-color:${color}`}>
          <strong>{title}</strong>
          <span>{desc}</span>
          <em>查看文章 →</em>
        </a>
      ))}
    </section>

<!--修改推薦文章樣式 start-->
    <section class="roundup-section" aria-labelledby="roundup-title">
      <h2 class="roundup-label" id="roundup-title">
        寫超完整懶人包
      </h2>
    
      <div class="roundup-grid">
        {roundup.map((post) => (
          <article class="roundup-card">
            <a
              class="roundup-cover"
              href={`/blog/${post.slug}/`}
              aria-label={`閱讀文章：${post.data.title}`}
            >
              <img
                src={post.data.cover ?? '/sample-cover.png'}
                alt={post.data.coverAlt ?? post.data.title}
                loading="lazy"
                decoding="async"
              />
    
              <span class="roundup-overlay" aria-hidden="true"></span>
    
              <span class="roundup-category">
                {post.data.category}
              </span>
    
              <div class="roundup-text">
                <h3>{post.data.title}</h3>
    
                <time datetime={post.data.pubDate.toISOString()}>
                  ↻ {post.data.pubDate.toLocaleDateString('zh-TW')}
                </time>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
<!--修改推薦文章樣式 end-->

    <section class="tabbed-articles" aria-labelledby="tabbed-title">
      <h2 id="tabbed-title" class="visually-hidden">最新文章與熱門文章</h2>

      <div class="article-tabs" role="tablist" aria-label="文章排序">
        <button
          class="article-tab is-active"
          type="button"
          role="tab"
          aria-selected="true"
          data-tab="latest"
        >
          最新文章
        </button>
        <button
          class="article-tab"
          type="button"
          role="tab"
          aria-selected="false"
          data-tab="popular"
        >
          熱門文章
        </button>
      </div>

      <div class="tab-feedback" id="tabFeedback" aria-live="polite">正在查看最新文章</div>
      <div class="tabbed-grid" id="tabbedArticleGrid" aria-live="polite"></div>
      <nav class="home-pagination" id="homePagination" aria-label="文章分頁"></nav>
    </section>
  </main>

  <script define:vars={{ serializedLatest, serializedPopular }}>
    const articleData = {
      latest: serializedLatest,
      popular: serializedPopular,
    };

    const grid = document.getElementById('tabbedArticleGrid');
    const pagination = document.getElementById('homePagination');
    const feedback = document.getElementById('tabFeedback');
    const tabs = Array.from(document.querySelectorAll('.article-tab'));
    const pageSize = 6;
    let activeTab = 'latest';
    let activePage = 1;

    const escapeHtml = (value) => String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

    function renderArticles({ animate = false } = {}) {
      if (animate) {
        grid.classList.add('is-changing');
      }
      const items = articleData[activeTab] || [];
      const totalPages = Math.max(1, Math.ceil(items.length / pageSize));
      activePage = Math.min(activePage, totalPages);
      const start = (activePage - 1) * pageSize;
      const visible = items.slice(start, start + pageSize);

      if (!visible.length) {
        grid.innerHTML = '<p class="empty-articles">目前尚未有文章。</p>';
      } else {
        grid.innerHTML = visible.map((item) => `
          <article class="tabbed-card">
            <a class="tabbed-cover" href="${escapeHtml(item.url)}">
              <img src="${escapeHtml(item.cover)}" alt="${escapeHtml(item.coverAlt)}" loading="lazy" />
            </a>
            <div class="tabbed-card-body">
              <span class="tabbed-category">${escapeHtml(item.category)}</span>
              <h3><a href="${escapeHtml(item.url)}">${escapeHtml(item.title)}</a></h3>
              <time>◷ ${escapeHtml(item.date)}</time>
            </div>
          </article>
        `).join('');
      }

      renderPagination(totalPages);

      if (feedback) {
        feedback.textContent = activeTab === 'latest' ? '正在查看最新文章' : '正在查看热门文章';
        feedback.dataset.mode = activeTab;
      }

      requestAnimationFrame(() => {
        grid.classList.remove('is-changing');
        grid.classList.add('is-entering');
        window.setTimeout(() => grid.classList.remove('is-entering'), 420);
      });
    }

    function renderPagination(totalPages) {
      const visiblePages = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i += 1) visiblePages.push(i);
      } else {
        visiblePages.push(1, 2, 3, 'ellipsis', totalPages);
      }

      pagination.innerHTML = visiblePages.map((page) => {
        if (page === 'ellipsis') return '<span class="pagination-ellipsis" aria-hidden="true">…</span>';
        const isActive = page === activePage;
        return `<button type="button" class="pagination-button${isActive ? ' is-active' : ''}" data-page="${page}" aria-current="${isActive ? 'page' : 'false'}">${page}</button>`;
      }).join('');

      pagination.querySelectorAll('[data-page]').forEach((button) => {
        button.addEventListener('click', () => {
          activePage = Number(button.dataset.page);
          renderArticles({ animate: true });
          document.querySelector('.tabbed-articles')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeTab = tab.dataset.tab;
        activePage = 1;
        tabs.forEach((item) => {
          const selected = item === tab;
          item.classList.toggle('is-active', selected);
          item.setAttribute('aria-selected', selected ? 'true' : 'false');
        });
        tab.classList.remove('is-bouncing');
        void tab.offsetWidth;
        tab.classList.add('is-bouncing');
        window.setTimeout(() => tab.classList.remove('is-bouncing'), 460);
        renderArticles({ animate: true });
      });
    });

    document.addEventListener('pointerdown', (event) => {
      const target = event.target.closest('.article-tab, .pagination-button, .category-card, .roundup-cover, .tabbed-cover, .tabbed-card h3 a');
      if (!target) return;
      const rect = target.getBoundingClientRect();
      const ripple = document.createElement('span');
      ripple.className = 'playful-ripple';
      ripple.style.left = `${event.clientX - rect.left}px`;
      ripple.style.top = `${event.clientY - rect.top}px`;
      target.appendChild(ripple);
      window.setTimeout(() => ripple.remove(), 600);
    });

    renderArticles();
  </script>
</BaseLayout>
