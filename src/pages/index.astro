---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPosts = posts.filter((post) => post.data.featured);
const roundup = (featuredPosts.length >= 5 ? featuredPosts : posts).slice(0, 5);
const latestPosts = posts;
const popularPosts = [...posts].sort((a, b) => {
  const aScore = a.data.featured ? 1 : 0;
  const bScore = b.data.featured ? 1 : 0;
  if (aScore !== bScore) return bScore - aScore;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const categories = [
  ['幼兒英文', '孩子從零開始的學習紀錄', '/blog?topic=幼兒英文', '#fcecef'],
  ['線上外師課', '試聽、選老師與真實上課心得', '/blog?topic=線上外師課', '#edf5e9'],
  ['免費英文資源', 'Starfall、Khan Academy Kids 與家庭用法', '/resources', '#f6f0fb'],
  ['家庭陪學', '忙碌家庭也能執行的短時間練習', '/blog?topic=家庭陪學', '#fff3dc'],
];

const serializedLatest = latestPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  date: post.data.pubDate.toLocaleDateString('zh-TW'),
  cover: post.data.cover ?? '/sample-cover.png',
  coverAlt: post.data.coverAlt ?? post.data.title,
  url: `/blog/${post.slug}/`,
}));

const serializedPopular = popularPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  date: post.data.pubDate.toLocaleDateString('zh-TW'),
  cover: post.data.cover ?? '/sample-cover.png',
  coverAlt: post.data.coverAlt ?? post.data.title,
  url: `/blog/${post.slug}/`,
}));
---
<BaseLayout
  title="Rose Lab 自學研究所｜台灣家庭幼兒英文與自學紀錄"
  description="Rose Lab 分享台灣家庭的幼兒英文、免費學習資源、線上外師課與家庭陪學實際紀錄。"
>
  <main class="home wrap">
    <section class="home-intro">
      <p class="eyebrow">台灣家庭的幼兒英文與自學紀錄</p>
      <h1>陪孩子找到適合自己的學習方法</h1>
      <p>用真實紀錄整理免費資源、家庭陪學與線上外師課經驗。內容以台灣家長的實際需求為中心，不追求速成，也不只分享成功。</p>
    </section>

    <section class="category-grid" aria-label="重要分類">
      {categories.map(([title, desc, url, color]) => (
        <a class="category-card" href={url} style={`--card-color:${color}`}>
          <strong>{title}</strong>
          <span>{desc}</span>
          <em>查看文章 →</em>
        </a>
      ))}
    </section>

    <section class="roundup-section" aria-labelledby="roundup-title">
      <div class="roundup-label" id="roundup-title">寫超完整懶人包</div>
      <div class="roundup-grid">
        {roundup.map((post, index) => (
          <article class={`roundup-card ${index === 0 ? 'roundup-card-large' : ''}`}>
            <a class="roundup-cover" href={`/blog/${post.slug}/`}>
              <img
                src={post.data.cover ?? '/sample-cover.png'}
                alt={post.data.coverAlt ?? post.data.title}
              />
              <span class="roundup-overlay" aria-hidden="true"></span>
              <div class="roundup-text">
                <span class="roundup-category">{post.data.category}</span>
                <h2>{post.data.title}</h2>
                <time>↻ {post.data.pubDate.toLocaleDateString('zh-TW')}</time>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="tabbed-articles" aria-labelledby="tabbed-title">
      <h2 id="tabbed-title" class="visually-hidden">最新文章與熱門文章</h2>

      <div class="article-tabs" role="tablist" aria-label="文章排序">
        <button
          class="article-tab is-active"
          type="button"
          role="tab"
          aria-selected="true"
          data-tab="latest"
        >
          最新文章
        </button>
        <button
          class="article-tab"
          type="button"
          role="tab"
          aria-selected="false"
          data-tab="popular"
        >
          熱門文章
        </button>
      </div>

      <div class="tabbed-grid" id="tabbedArticleGrid" aria-live="polite"></div>
      <nav class="home-pagination" id="homePagination" aria-label="文章分頁"></nav>
    </section>
  </main>

  <script define:vars={{ serializedLatest, serializedPopular }}>
    const articleData = {
      latest: serializedLatest,
      popular: serializedPopular,
    };

    const grid = document.getElementById('tabbedArticleGrid');
    const pagination = document.getElementById('homePagination');
    const tabs = Array.from(document.querySelectorAll('.article-tab'));
    const pageSize = 6;
    let activeTab = 'latest';
    let activePage = 1;

    const escapeHtml = (value) => String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

    function renderArticles() {
      const items = articleData[activeTab] || [];
      const totalPages = Math.max(1, Math.ceil(items.length / pageSize));
      activePage = Math.min(activePage, totalPages);
      const start = (activePage - 1) * pageSize;
      const visible = items.slice(start, start + pageSize);

      if (!visible.length) {
        grid.innerHTML = '<p class="empty-articles">目前尚未有文章。</p>';
      } else {
        grid.innerHTML = visible.map((item) => `
          <article class="tabbed-card">
            <a class="tabbed-cover" href="${escapeHtml(item.url)}">
              <img src="${escapeHtml(item.cover)}" alt="${escapeHtml(item.coverAlt)}" loading="lazy" />
            </a>
            <div class="tabbed-card-body">
              <span class="tabbed-category">${escapeHtml(item.category)}</span>
              <h3><a href="${escapeHtml(item.url)}">${escapeHtml(item.title)}</a></h3>
              <time>◷ ${escapeHtml(item.date)}</time>
            </div>
          </article>
        `).join('');
      }

      renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
      const visiblePages = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i += 1) visiblePages.push(i);
      } else {
        visiblePages.push(1, 2, 3, 'ellipsis', totalPages);
      }

      pagination.innerHTML = visiblePages.map((page) => {
        if (page === 'ellipsis') return '<span class="pagination-ellipsis" aria-hidden="true">…</span>';
        const isActive = page === activePage;
        return `<button type="button" class="pagination-button${isActive ? ' is-active' : ''}" data-page="${page}" aria-current="${isActive ? 'page' : 'false'}">${page}</button>`;
      }).join('');

      pagination.querySelectorAll('[data-page]').forEach((button) => {
        button.addEventListener('click', () => {
          activePage = Number(button.dataset.page);
          renderArticles();
          document.querySelector('.tabbed-articles')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeTab = tab.dataset.tab;
        activePage = 1;
        tabs.forEach((item) => {
          const selected = item === tab;
          item.classList.toggle('is-active', selected);
          item.setAttribute('aria-selected', selected ? 'true' : 'false');
        });
        renderArticles();
      });
    });

    renderArticles();
  </script>
</BaseLayout>
