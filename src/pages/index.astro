---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const allPosts = (await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const featured = allPosts.find(post => post.data.featured) ?? allPosts[0];
const latest = allPosts.slice(0, 5);
---
<BaseLayout title="Rose Lab 自學研究所｜台灣家庭幼兒英文與自學紀錄" description="Rose Lab 分享台灣家庭的幼兒英文、自學方法、免費英文資源、線上外師課與家庭陪學紀錄。">
  <section class="home-hero">
    <div class="wrap home-hero-grid">
      <div class="home-hero-copy">
        <p class="section-kicker">ROSE LAB 自學研究所</p>
        <h1>把學習變成一座<br />慢慢長大的花園</h1>
        <p class="lead">陪孩子建立適合自己的學習習慣。這裡整理幼兒英文、免費 App、家庭陪學與線上外師課的真實紀錄，讓台灣家長更容易找到可以直接參考的方法。</p>
        <div class="hero-actions">
          <a class="btn" href="/start">新讀者從這裡開始</a>
          <a class="btn alt" href="/blog">瀏覽全部文章</a>
        </div>
      </div>
      <div class="home-hero-image">
        <img src="/rose-lab-visual.png" alt="Rose Lab 玫瑰、大自然與自學筆記主視覺" />
      </div>
    </div>
  </section>

  <section class="topic-strip">
    <div class="wrap topic-strip-inner">
      <a href="/blog?topic=線上外師課"><span>01</span>線上外師課</a>
      <a href="/resources"><span>02</span>免費英文資源</a>
      <a href="/blog?topic=家庭陪學"><span>03</span>家庭陪學</a>
      <a href="/blog?topic=家庭選擇"><span>04</span>教育選擇與預算</a>
    </div>
  </section>

  <section class="section">
    <div class="wrap portal-grid">
      <div class="portal-main">
        <div class="section-heading compact">
          <div>
            <p class="section-kicker">FEATURED GUIDE</p>
            <h2>精選長文</h2>
          </div>
        </div>

        {featured && (
          <a class="featured-story" href={`/blog/${featured.slug}/`}>
            <div class="featured-story-art">
              <div class="botanical-mark">🌹</div>
              <p>ROSE LAB<br />FEATURED</p>
            </div>
            <div class="featured-story-copy">
              <span class="tag">{featured.data.category}</span>
              <h2>{featured.data.title}</h2>
              <p>{featured.data.description}</p>
              <span class="text-link">閱讀完整文章 →</span>
            </div>
          </a>
        )}

        <div class="section-heading compact top-gap">
          <div>
            <p class="section-kicker">TOPIC GUIDES</p>
            <h2>依需求找內容</h2>
          </div>
        </div>

        <div class="guide-list">
          <a class="guide-row" href="/start">
            <div class="guide-number">01</div>
            <div><h3>第一次來 Rose Lab</h3><p>先了解我們家的學習起點、使用工具與閱讀順序。</p></div>
            <span>→</span>
          </a>
          <a class="guide-row" href="/resources">
            <div class="guide-number">02</div>
            <div><h3>免費 App 與家庭資源</h3><p>看 Starfall、Khan Academy Kids 與短時間練習怎麼搭配。</p></div>
            <span>→</span>
          </a>
          <a class="guide-row" href="/trial-guide">
            <div class="guide-number">03</div>
            <div><h3>線上外師課試聽指南</h3><p>預約試聽前，先看老師互動、孩子反應與家長陪課方式。</p></div>
            <span>→</span>
          </a>
          <a class="guide-row" href="/blog/not-all-english-kindergarten/">
            <div class="guide-number">04</div>
            <div><h3>不讀全美語幼兒園的家庭方案</h3><p>從時間、預算與孩子反應出發，安排可持續的英文學習。</p></div>
            <span>→</span>
          </a>
        </div>
      </div>

      <aside class="portal-side">
        <div class="side-card">
          <p class="section-kicker">RECENTLY UPDATED</p>
          <h2>最近更新</h2>
          <div class="recent-list">
            {latest.map((post, index) => (
              <a href={`/blog/${post.slug}/`}>
                <span class="recent-index">{String(index + 1).padStart(2,'0')}</span>
                <div>
                  <strong>{post.data.title}</strong>
                  <small>{post.data.pubDate.toLocaleDateString('zh-TW')}</small>
                </div>
              </a>
            ))}
          </div>
          <a class="side-more" href="/blog">查看全部文章 →</a>
        </div>

        <div class="side-card soft-card">
          <div class="mini-rose">🌿</div>
          <h3>給正在考慮試聽的家長</h3>
          <p>先看 10 堂課心得，再看試聽指南，比直接點推薦連結更容易判斷是否適合自己的孩子。</p>
          <a class="btn side-btn" href="/trial-guide">試聽前先看</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section garden-section">
    <div class="wrap">
      <div class="section-heading">
        <div>
          <p class="section-kicker">CONTENT GARDEN</p>
          <h2>Rose Lab 的內容花園</h2>
        </div>
        <a class="text-link" href="/blog">進入文章總覽 →</a>
      </div>

      <div class="garden-grid">
        <a class="garden-card rose" href="/blog?topic=線上外師課">
          <span>外師課紀錄</span>
          <h3>孩子不開口時，家長可以怎麼觀察？</h3>
          <p>整理老師節奏、提問方式、等待時間與孩子情緒。</p>
        </a>
        <a class="garden-card green" href="/resources">
          <span>免費資源</span>
          <h3>App 可以做什麼，又有哪些事情做不到？</h3>
          <p>把免費資源放在正確的位置，不追求一次塞滿內容。</p>
        </a>
        <a class="garden-card beige" href="/blog?topic=家庭陪學">
          <span>家庭陪學</span>
          <h3>家長英文不好，也能陪孩子慢慢開始</h3>
          <p>從每天一句、短時間複習與生活情境開始。</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap newsletter-card">
      <div>
        <p class="section-kicker">FOLLOW THE JOURNEY</p>
        <h2>从 Threads 看短纪录，到网站读完整方法</h2>
        <p class="muted">Threads 用来分享即时学习片段，Rose Lab 网站则保存完整心得、步骤与长期更新。</p>
      </div>
      <a class="btn" href="/about">认识 Rose Lab</a>
    </div>
  </section>
</BaseLayout>
