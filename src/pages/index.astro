---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts=(await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const featured=posts.filter(p=>p.data.featured).slice(0,1);
const lead=featured[0] ?? posts[0];
const latest=posts.filter(p=>p.slug!==lead?.slug).slice(0,6);
const popular=(posts.filter(p=>p.data.featured).length?posts.filter(p=>p.data.featured):posts).slice(0,5);
const categories=[
  ['幼兒英文','孩子從零開始的學習紀錄','/blog?topic=幼兒英文','#fcecef'],
  ['線上外師課','試聽、選老師與真實上課心得','/blog?topic=線上外師課','#edf5e9'],
  ['免費英文資源','Starfall、Khan Academy Kids 與家庭用法','/resources','#f6f0fb'],
  ['家庭陪學','忙碌家庭也能執行的短時間練習','/blog?topic=家庭陪學','#fff3dc'],
];
---
<BaseLayout title="Rose Lab 自學研究所｜台灣家庭幼兒英文與自學紀錄" description="Rose Lab 分享台灣家庭的幼兒英文、免費學習資源、線上外師課與家庭陪學實際紀錄。">
  <main class="home wrap">
    <section class="home-intro">
      <p class="eyebrow">台灣家庭的幼兒英文與自學紀錄</p>
      <h1>陪孩子找到適合自己的學習方法</h1>
      <p>用真實紀錄整理免費資源、家庭陪學與線上外師課經驗。內容以台灣家長的实际需求为中心，不追求速成，也不只分享成功。</p>
    </section>

    <section class="category-grid" aria-label="重要分類">
      {categories.map(([title,desc,url,color])=>(
        <a class="category-card" href={url} style={`--card-color:${color}`}>
          <strong>{title}</strong><span>{desc}</span><em>查看文章 →</em>
        </a>
      ))}
    </section>

    {lead && <section class="featured-story">
      <a class="featured-cover" href={`/blog/${lead.slug}/`}>
        <img src={lead.data.cover ?? '/sample-cover.png'} alt={lead.data.coverAlt ?? lead.data.title} />
      </a>
      <div class="featured-copy">
        <span class="tag">精選長文 · {lead.data.category}</span>
        <h2><a href={`/blog/${lead.slug}/`}>{lead.data.title}</a></h2>
        <p>{lead.data.description}</p>
        <time>{lead.data.pubDate.toLocaleDateString('zh-TW')}</time>
        <a class="read-more" href={`/blog/${lead.slug}/`}>閱讀全文</a>
      </div>
    </section>}

    <section class="home-section">
      <div class="section-head"><h2>最近更新</h2><a href="/blog">查看全部文章</a></div>
      <div class="article-grid">
        {latest.map(post=>(
          <article class="article-card">
            <a class="article-cover" href={`/blog/${post.slug}/`}><img src={post.data.cover ?? '/sample-cover.png'} alt={post.data.coverAlt ?? post.data.title} /></a>
            <div class="article-card-body">
              <span class="tag">{post.data.category}</span>
              <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="home-section home-lists">
      <div>
        <div class="section-head"><h2>新手先看</h2></div>
        <ol class="rank-list">
          <li><a href="/start">第一次来 Rose Lab，从这里开始</a></li>
          <li><a href="/trial-guide">线上外师课试听前，家长先看什么</a></li>
          <li><a href="/resources">我们实际使用的免费英文资源</a></li>
        </ol>
      </div>
      <div>
        <div class="section-head"><h2>热门文章</h2></div>
        <ol class="rank-list">
          {popular.map(post=><li><a href={`/blog/${post.slug}/`}>{post.data.title}</a></li>)}
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>
