---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const featured = posts.slice(0,5);
const latest = posts.slice(0,10);
const groups = [
  { title: '幼兒英文', items: posts.filter(p => ['幼兒英文','家庭陪學'].includes(p.data.category)).slice(0,6), more: '/blog?topic=幼兒英文' },
  { title: '線上外師課', items: posts.filter(p => p.data.category === '線上外師課').slice(0,6), more: '/blog?topic=線上外師課' },
  { title: '家庭學習與資源', items: posts.filter(p => ['家庭選擇','家庭陪學'].includes(p.data.category)).slice(0,6), more: '/blog?topic=家庭陪學' },
];
---
<BaseLayout title="Rose Lab 自學研究所｜台灣家庭幼兒英文與自學紀錄" description="Rose Lab 分享台灣家庭的幼兒英文、免費學習資源、線上外師課與家庭陪學實際紀錄。">
  <main class="home wrap">
    <section class="category-icons" aria-label="內容分類">
      <a href="/start"><span>01</span><strong>從這裡開始</strong><small>Start Here</small></a>
      <a href="/blog?topic=幼兒英文"><span>02</span><strong>幼兒英文</strong><small>English for Kids</small></a>
      <a href="/blog?topic=線上外師課"><span>03</span><strong>線上外師課</strong><small>Online Classes</small></a>
      <a href="/resources"><span>04</span><strong>免費資源</strong><small>Free Resources</small></a>
      <a href="/blog?topic=家庭陪學"><span>05</span><strong>家庭陪學</strong><small>Family Learning</small></a>
      <a href="/about"><span>06</span><strong>關於我們</strong><small>About</small></a>
    </section>

    <section class="block featured-block">
      <h1 class="block-title">寫很久的完整整理</h1>
      <ol class="headline-list">
        {featured.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`}>
              <strong>{post.data.title}</strong>
              <time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="block">
      <h2 class="block-title">最近更新</h2>
      <div class="update-columns">
        {groups.map(group => (
          <section class="update-group">
            <h3>{group.title}</h3>
            <ul>
              {group.items.length ? group.items.map(post => (
                <li><a href={`/blog/${post.slug}/`}><time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time><span>{post.data.title}</span></a></li>
              )) : <li class="empty">文章准备中</li>}
            </ul>
            <a class="more-link" href={group.more}>觀看更多</a>
          </section>
        ))}
      </div>
    </section>

    <section class="block article-stream">
      <div class="tab-row"><strong>最新文章</strong><span>熱門文章</span></div>
      <div class="simple-post-list">
        {latest.map(post => (
          <article>
            <a href={`/blog/${post.slug}/`}>
              <span class="post-category">{post.data.category}</span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="post-dates"><time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time></div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
