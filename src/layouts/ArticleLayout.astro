---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
const { frontmatter }=Astro.props;
const posts=(await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const latest=posts.slice(0,4);
const popular=(posts.filter(p=>p.data.featured).length?posts.filter(p=>p.data.featured):posts).slice(0,4);
---
<BaseLayout title={`${frontmatter.title}｜Rose Lab`} description={frontmatter.description}>
  <main class="article-page">
    <div class="article-wrap">
      <nav class="breadcrumbs"><a href="/">首頁</a><span>›</span><a href="/blog">文章</a><span>›</span><span>{frontmatter.category}</span></nav>
      <article>
        <header class="article-header">
          <span class="tag">{frontmatter.category}</span>
          <h1>{frontmatter.title}</h1>
          <p class="article-description">{frontmatter.description}</p>
          <div class="article-meta"><time>{frontmatter.pubDate.toLocaleDateString('zh-TW')}</time>{frontmatter.updatedDate&&<span>更新 {frontmatter.updatedDate.toLocaleDateString('zh-TW')}</span>}</div>
          {frontmatter.cover&&<figure class="article-cover-main"><img src={frontmatter.cover} alt={frontmatter.coverAlt ?? frontmatter.title} /></figure>}
        </header>

        <section class="highlight-box highlight-summary"><strong>先看重点</strong><p>这里放文章最重要的结论，让读者在一分钟内判断这篇内容是否适合自己。</p></section>

        <section class="toc-box"><h2>文章目录</h2><nav id="article-toc"></nav></section>

        <div class="article-body" id="article-body"><slot /></div>

        <section class="disclosure-box"><strong>内容说明</strong><p>本文记录我们家的实际经验，不代表每个孩子都会有相同结果。部分文章可能含推荐连结，但不会影响对优点与问题的真实描述。</p></section>
      </article>

      <section class="related-grid">
        <div><h2>最新文章</h2><ul>{latest.map(post=><li><a href={`/blog/${post.slug}/`}>{post.data.title}</a><time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time></li>)}</ul></div>
        <div><h2>热门文章</h2><ul>{popular.map(post=><li><a href={`/blog/${post.slug}/`}>{post.data.title}</a><time>{post.data.pubDate.toLocaleDateString('zh-TW')}</time></li>)}</ul></div>
      </section>
    </div>
  </main>
  <script is:inline>
    (()=>{const body=document.getElementById('article-body');const toc=document.getElementById('article-toc');if(!body||!toc)return;const hs=[...body.querySelectorAll('h2,h3')];hs.forEach((h,i)=>{if(!h.id)h.id=`section-${i+1}`;const a=document.createElement('a');a.href=`#${h.id}`;a.textContent=h.textContent||'';a.className=h.tagName==='H3'?'toc-h3':'toc-h2';toc.appendChild(a);});if(!hs.length)toc.innerHTML='<span>在文章中加入二级标题后，目录会自动产生。</span>';})();
  </script>
</BaseLayout>
